{
  "aartis": [
    {
      "id": "ganesh_prarthana",
      "title": "श्री गणेशाय नमः",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "prarthana",
          "lines": [
            "प्रारंभी विनंती करू गणपती विद्यादयासागरा ।",
            "अज्ञानत्व हरोनी बुद्धी मति दे आराध्य मोरेश्वरा ।",
            "चिंता क्लेश दरिद्र दुःख अवघे देशांतरा पाठवी ।",
            "हेरंबा गणनायका गजमुखा भक्तां बहु तोषवी ।।"
          ]
        }
      ]
    },
    {
      "id": "ganesh_aarti_1",
      "title": "श्री गणेश आरती १",
      "author": "समर्थ रामदासस्वामी",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "सुखकर्ता दुःखहर्ता वार्ता विघ्नाची ।",
            "नुरवी पुरवी प्रेम कृपा जयाची ।",
            "सर्वांगी सुंदर उटी शेंदुराची ।",
            "कंठी झळके माळ मुक्ताफळाची ।।"
          ]
        },
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय देव जय देव जय मंगल मूर्ती ।",
            "दर्शनमात्रे मन कामनापूर्ती ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "रत्नखचित फरा तुज गौरीकुमरा ।",
            "चंदनाची उटी कुंकुम केशरा ।",
            "हिरे जडित मुकुट शोभतो बरा ।",
            "रुणझुणती नूपुरे चरणी घागरिया ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "लंबोदर पीतांबर फणिवरबंधना ।",
            "सरळ सोंड वक्रतुंड त्रिनयना ।",
            "दास रामाचा वाट पाहे सदना ।",
            "संकटी पावावे निर्वाणी रक्षावे सुरवरवंदना ।। जय देव"
          ]
        }
      ]
    },
    {
      "id": "ganesh_aarti_2",
      "title": "श्री गणेश आरती २",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "नाना परिमळ दूर्वा शेंदूर शमीपत्रे ।",
            "लाडू मोदक अन्ने परिपूरित पात्रं ।।",
            "ऐसे पूजन केल्या बीजाक्षर मंत्र ।",
            "अष्टहि सिद्धी नवनिधी देसी क्षणमात्रं ।। १ ।।"
          ]
        },
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय देव जय देव जय मंगलमूर्ती ।",
            "तुझे गुण वर्णाया मज कैसी स्फूर्ती ।। धृ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "तुझें ध्यान निरंतर जे कोणी करिती ।",
            "त्यांची सकलहि पापें विघ्नेही हरति ।",
            "वाजी वारण शिबिका सेवक सुत युवती ।",
            "सर्वहि पावनि अंतीं भवसागर तरती ।। जय देव ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "शरणागत सर्वस्वें भजती तव चरणीं ।",
            "कीर्ति तयांची राहे जोवरी शशि तरणी ।",
            "त्रैलोक्यों ते विजयी अद्भुत हे करणी ।",
            "गोसावीनंदन रत नामस्मरणीं ।। जय देव ।। ३ ।।"
          ]
        }
      ]
    },
    {
      "id": "ganesh_aarti_3",
      "title": "श्री गणेश आरती ३",
      "author": "गोसावीनंदन",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "शेंदुर लाल चढायो अच्छा गजमुखको ।",
            "दोंदिल लाल बिराजे सुत गौरिहरको ।",
            "हाथ लिये गुडलद्द साईं सुरवरको ।",
            "महिमा कहे न जाय लागत हूँ पदको ।। १ ।।"
          ]
        },
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय जय जी गणराज विद्या सुखदाता ।",
            "धन्य तुम्हार दर्शन मेरा मन रमता ।। धृ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "अष्टौ सिद्धी दासी संकटको बैरि ।",
            "विघ्नविनाशन मंगल मरत अधिकारी ।",
            "कोटीसूरजप्रकाश ऐसी छबि तेरी ।",
            "गंडस्थलमदमस्तक झूले शशिबिहारि ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "भावभगतसे कोई शरणागत आवे ।",
            "संतत संपत सबही भरपूर पावे ।",
            "ऐसे तुम महाराज मोको अति भावे ।",
            "गोसावीनंदन निशिदिन गुन गावे ।। ३ ।।"
          ]
        }
      ]
    },
    {
      "id": "ganesh_aarti_4",
      "title": "श्रीगणेश आरती ४",
      "author": "गोसावीनंदन",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "कपोल झरती मदें शुण्डा बहु साजे ।",
            "शेंदुर जो घवघवीत अद्भुत सुविराजे ।",
            "घागरियांचा घोळ पदी घुळघुळ वाजे ।",
            "प्रसन्नवदना देवा ध्याना सुख माजे ।। १ ।।"
          ]
        },
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय देव जय देव गजनरवेषा ।",
            "आरती ओवाळू तुजला विश्वेशा ।। धृ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "विशेष महिमा तुझा नकळे गणनाथा ।",
            "हरिसी संकट विघ्ने तापत्रयव्यथा ।",
            "अखण्ड आनंदे तु डोलविसी माथा ।",
            "ताण्डवनृत्य करिसी तात धिम ताथा ।। जय ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "विद्या धनसंपदा कनकाच्या राशी ।",
            "नारी सुत मंदिरे सर्वहि तू देशी ।",
            "निर्वाणी पावशी वेगी भक्तांसी ।",
            "गोसावीनंदन गातो कवितांशी ।। जय ।। ३ ।।"
          ]
        }
      ]
    },
    {
      "id": "ganesh_aarti_5",
      "title": "श्री गणेश आरती ५",
      "category": "Ganpati",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय देव जय देव जय वक्रतुंडा ।",
            "सिंदूरमंडित विशाल सरळ भुजदंडा ।। जय ।। धृ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "प्रसन्नभाळा विमला करी घेऊनि कमळा ।",
            "उंदिरवाहन दोलिल नाचसी बहुलीला ।",
            "रुणझुण करिती घागरिया घोळा ।",
            "सतार सुस्वर गायन शोभित अवलीला ।। जय ।। १ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "सारीगमपधनी सप्तस्वर भेदा ।",
            "धिमिकिट धिमिकिट मृदंग वाजति गतिछंदा ।",
            "तातक तातक भैय्या करिसि आनंदा ।",
            "ब्रह्मादिक अवलोकिती तव पदारविंदा ।। जय ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "अभयवरदा सुखदा राजिवदलनयना ।",
            "परशांकुशल दुर्धर शोभित शुभवदना ।",
            "ऊर्ध्वदोलिल उंदिर कार्तिकेश्वर रचना ।",
            "मुक्तेश्वर चरणांबुजीं अलिपरि करी भ्रमणा ।। जय ।। ३ ।।"
          ]
        }
      ]
    },
    {
      "id": "datt_aarti",
      "title": "श्री दत्त आरती",
      "author": "संत एकनाथ",
      "category": "Datt",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "lines": [
            "त्रिगुणात्मक त्रैमूर्ती दत्त हा जाणा ।",
            "त्रिगुणी अवतार त्रैलोक्य राणा ।",
            "नेती नेती शब्द न ये अनुमाना ।",
            "सुरवर मुनिजन योगे समाधी न ये ध्यान ।।"
          ]
        },
        {
          "type": "chorus",
          "lines": [
            "जय देव जय देव जय श्री गुरुदत्ता ।",
            "आरति ओवाळीता हरली भवचिन्ता ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "lines": [
            "सबाह्य अभ्यंतरी तू एक दत्त ।",
            "अभाग्यासी कैसी नकळे ही मात ।",
            "पराही परतली कैसा हा हेत ।",
            "जन्म मरणाचा पुरलासे अंत ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "lines": [
            "दत्त येऊनिया उभा ठाकला ।",
            "सद्भावे साष्टांग प्रणिपात केला ।",
            "प्रसन्न होऊनिया आशीर्वाद दिधला ।",
            "जन्मा मरणाचा फेरा वाचविला ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "lines": [
            "दत्त दत्त ऐसे लागले ध्यान ।",
            "हरपले मन झाले उन्मन ।",
            "मी तू पणाची झाली बोळवण ।",
            "एका जनार्दनी श्री दत्त ध्यान ।। जय देव"
          ]
        }
      ]
    },
    {
      "id": "vitthal_aarti_1",
      "title": "श्री विठ्ठल आरती १",
      "author": "संत नामदेव",
      "category": "Vitthal",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "युगे अठ्ठावीस विटेवरी उभा ।",
            "वामांगी रखुमाई दिसे दिव्य शोभा ।",
            "पुंडलिकाचे भेटी परब्रह्म आले गा ।",
            "चरणी वाहे भीमा उद्धरी जगा ।।"
          ]
        },
        {
          "type": "chorus",
          "lines": [
            "जय देव जय देव जय पांडुरंगा ।",
            "रखुमाई वल्लभा राईच्या वल्लभा ।",
            "पावे जिवलगा ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "तुळसी माळा गळा कर ठेवुनी कटी ।",
            "कासे पितांबर कस्तुरी लल्लाटी ।",
            "देव सुरवर नित्य येती भेटी ।",
            "गरुड हनुमंत पुढे उभे राहती ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "धन्य वेणुनाद अनुक्षेत्रपाळा ।",
            "सुवर्णाची कमळे वनमाळा गळा ।",
            "राई रखुमाबाई राणीया सकळा ।",
            "ओवाळ आरत्या विठोबा सावळा ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "ओवाळू आरत्या कुरवंड्या येती ।",
            "चंद्रभागेमध्ये सोडुनिया देती ।",
            "दिंड्या पताका वैष्णव नाचती ।",
            "पंढरीचा महिमा वर्णावा किती ।। जय देव"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "आषाढी कार्तिकी भक्तजन येती ।",
            "चंद्रभागेमध्ये स्नान जे करती ।",
            "दर्शन हेळामात्रे तया होय मुक्ती ।",
            "केशवासी नामदेव भावे ओवाळिती ।। जय देव"
          ]
        }
      ]
    },
    {
      "id": "vitthal_aarti_2",
      "title": "श्री विठ्ठल आरती २",
      "author": "संत नामदेव",
      "category": "Vitthal",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "येई हो विठ्ठले माझे माऊली ये ।",
            "निढळावरी कर ठेवुनि वाट मी पाहे ।। धृ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "आलिया गेलिया हाती धाडी निरोप ।",
            "पंढरपूरी आहे माझा मायबाप ।। १ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "पिवळा पीतांबर कैसा गगनी झळकला ।",
            "गरुडांवरी बैसोनि माझा कैवारी आला ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "विठोबाचे राज्य आम्हां नित्य दिपवाळी ।",
            "विष्णुदास नामा जीवेंभावे ओंवाळी ।। ३ ।।"
          ]
        }
      ]
    },
    {
      "id": "vitthal_aarti_3",
      "title": "श्री विठ्ठल आरती ३",
      "category": "Vitthal",
      "language": "mr",
      "script": "devanagari",
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "ओवाळू ग माये विठ्ठल सबाह्य साजिरा ।",
            "राई रखुमाबाई सत्यभामेच्या वरा ।। धृ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "कनकाचे पर्यळी उजळोनि आरती रत्नदीपशोभा कैशा प्रकाशल्या ज्योती ।। ओवाळू ।। १ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "मंडित चतुर्भुज कानी शोभत कुंडले ।",
            "श्रीमुखाची शोभा पाहतां तेज फांकले ।। ओवाळू ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "वैजयंती माळ गळा शोभे स्यमंतक ।",
            "शंखचक्रगदापद्म आयु शोभत ।। ओवाळू ।। ३ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "सांवळा सुंदर जैसा कर्दळीचा गाभा ।",
            "चरणींची नूपुरें वांक्या गाजती नभा ।। ओवाळू ।। ४ ।।"
          ]
        },
