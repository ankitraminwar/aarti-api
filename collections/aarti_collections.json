          "title": "Shri Ganesh Aarti - Nana Parimal Durva Shendur Shamipatre",
          "type": "Aarti"
        },
        "mr": {
          "title": "श्री गणेश आरती - नाना परिमळ दूर्वा शेंदूर शमीपत्रे",
          "type": "आरती"
        }
      },
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "नाना परिमळ दूर्वा शेंदूर शमीपत्रे ।",
            "लाडू मोदक अन्ने परिपूरित पात्रं ।।",
            "ऐसे पूजन केल्या बीजाक्षर मंत्र ।",
            "अष्टहि सिद्धी नवनिधी देसी क्षणमात्रं ।। १ ।।"
          ]
        },
        {
          "type": "chorus",
          "label": "धृ",
          "lines": [
            "जय देव जय देव जय मंगलमूर्ती ।",
            "तुझे गुण वर्णाया मज कैसी स्फूर्ती ।। धृ।।"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "तुझें ध्यान निरंतर जे कोणी करिती ।",
            "त्यांची सकलहि पापें विघ्नेही हरति ।",
            "वाजी वारण शिबिका सेवक सुत युवती ।",
            "सर्वहि पावनि अंतीं भवसागर तरती ।। जय देव ।। २ ।।"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "शरणागत सर्वस्वें भजती तव चरणीं ।",
            "कीर्ति तयांची राहे जोवरी शशि तरणी ।",
            "त्रैलोक्यों ते विजयी अद्भुत हे करणी ।",
            "गोसावीनंदन रत नामस्मरणीं ।। जय देव ।। ३ ।।"
          ]
        }
      ]
    },
