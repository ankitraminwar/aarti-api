      "searchableText": "श्री रामचन्द्र कृपालु भजुमन हरण भवभय दारुणं नव कंज लोचन कंज मुख कर कंज पद कंजारुणं तुलसीदास राम स्तुति",
      "translations": {
        "hi": {
          "title": "श्री राम स्तुति",
          "type": "स्तुति",
          "category": "श्री राम"
        },
        "en": {
          "title": "Shri Ram Stuti",
          "type": "Stuti",
          "category": "Shri Ram"
        },
        "mr": {
          "title": "श्री राम स्तुति",
          "type": "स्तुती",
          "category": "श्री राम"
        }
      },
      "verses": [
        {
          "type": "doha",
          "number": 1,
          "lines": [
            "श्री रामचन्द्र कृपालु भजुमन",
            "हरण भवभय दारुणं ।",
            "नव कंज लोचन कंज मुख",
            "कर कंज पद कंजारुणं ॥१॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "कन्दर्प अगणित अमित छवि",
            "नव नील नीरद सुन्दरं ।",
            "पटपीत मानहुँ तडित रुचि शुचि",
            "नोमि जनक सुतावरं ॥२॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "भजु दीनबन्धु दिनेश दानव",
            "दैत्य वंश निकन्दनं ।",
            "रघुनन्द आनन्द कन्द कोशल",
            "चन्द दशरथ नन्दनं ॥३॥"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "शिर मुकुट कुंडल तिलक",
            "चारु उदारु अङ्ग विभूषणं ।",
            "आजानु भुज शर चाप धर",
            "संग्राम जित खरदूषणं ॥४॥"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "इति वदति तुलसीदास शंकर",
            "शेष मुनि मन रंजनं ।",
            "मम् हृदय कंज निवास कुरु",
            "कामादि खलदल गंजनं ॥५॥"
          ]
        },
        {
          "type": "verse",
          "number": 6,
          "lines": [
            "मन जाहि राच्यो मिलहि सो",
            "वर सहज सुन्दर सांवरो ।",
            "करुणा निधान सुजान शील",
            "स्नेह जानत रावरो ॥६॥"
          ]
        },
        {
          "type": "verse",
          "number": 7,
          "lines": [
            "एहि भांति गौरी असीस सुन सिय",
            "सहित हिय हरषित अली।",
            "तुलसी भवानिहि पूजी पुनि-पुनि",
            "मुदित मन मन्दिर चली ॥७॥"
          ]
        },
        {
          "type": "soratha",
          "number": 8,
          "lines": [
            "जानी गौरी अनुकूल सिय",
            "हिय हरषु न जाइ कहि ।",
            "मंजुल मंगल मूल वाम",
            "अङ्ग फरकन लगे।"
          ]
        }
      ]
    }
  ]
