      ],
      "searchableText": "पसायदान आतां विश्वात्मकें देवें येणे वाग्य तोषावे जो जें वांछील तो तें लाहो",
      "translations": {
        "hi": {
          "title": "पसायदान - सार्वभौमिक प्रार्थना",
          "type": "प्रार्थना",
          "category": "प्रार्थना"
        },
        "en": {
          "title": "Pasaydan - Universal Prayer",
          "type": "Prayer",
          "category": "Prayer"
        },
        "mr": {
          "title": "पसायदान - सार्वभौमिक प्रार्थना",
          "type": "प्रार्थना",
          "category": "प्रार्थना"
        }
      },
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "आतां विश्वात्मके देवे,",
            "येणे वाग्यज्ञे तोषावे,",
            "तोषोनि मज द्यावे,",
            "पसायदान हे ॥१॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "जे खळांचि व्यंकटी सांडो,",
            "तया सत्कर्मी रती वाढो,",
            "भूतां परस्परे जडो,",
            "मैत्र जीवांचे ॥२॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "दुरितांचे तिमिर जावो,",
            "विश्व स्वधर्म सूर्ये पाहो,",
            "जो जे वांछील तो ते लाहो,",
            "प्राणिजात ॥३॥"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "वर्षत सकळ मंडळी,",
            "ईश्वरनिष्ठांची मांदियाळी,",
            "अनवरत भूमंडळी,",
            "भेटतु भूता ॥४॥"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "चला कल्पतरूंचे आरव,",
            "चेतनाचिंतामणींचे गाव,",
            "बोलती जे अर्णव,",
            "पीयूषांचे ॥५॥"
          ]
        },
        {
          "type": "verse",
          "number": 6,
          "lines": [
            "चन्द्रमेंजे अलांछन,",
            "मार्तण्ड जे तापहीन,",
            "ते सर्वाही सदा सज्जन,",
            "सोयरे होतु ॥६॥"
          ]
        },
        {
          "type": "verse",
          "number": 7,
          "lines": [
            "किंबहुना सर्व सुखी,",
            "पूर्ण होवोनि तिहीं लोकी,",
            "भजिजो आदिपुरुषीं,",
            "अखण्डित ॥७॥"
          ]
        },
        {
          "type": "verse",
          "number": 8,
          "lines": [
            "आणि ग्रंथोपजिवीये,",
            "विशेषी लोकी इये,",
            "दृष्टादृष्टविजये,",
            "होआवेजी ॥८॥"
          ]
        },
        {
          "type": "verse",
          "number": 9,
          "lines": [
            "येथ म्हणे श्री विश्वेश्वरावो,",
            "हा होईल दानपसावो,",
            "येणे वरे ज्ञानदेवो,",
            "सुखिया झाला ॥९॥"
          ]
        }
      ]
    }
  ]
}