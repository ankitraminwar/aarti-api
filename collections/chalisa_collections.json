        "Hindi"
      ],
      "searchableText": "हनुमान चालीसा जय हनुमान ज्ञान गुन सागर राम दूत अतुलित बल धामा अंजनि पुत्र पवनसुत तुलसीदास",
      "translations": {
        "hi": {
          "title": "श्री हनुमान चालीसा",
          "type": "चालीसा"
        },
        "en": {
          "title": "Shri Hanuman Chalisa",
          "type": "Chalisa"
        },
        "mr": {
          "title": "श्री हनुमान चाळीसा",
          "type": "चाळीसा"
        }
      },
      "verses": [
        {
          "type": "doha",
          "number": 1,
          "lines": [
            "श्रीगुरु चरन सरोज रज निज मनु मुकुरु सुधारि ।",
            "बरनउँ रघुबर बिमल जसु जो दायकु फल चारि ।।"
          ]
        },
        {
          "type": "doha",
          "number": 2,
          "lines": [
            "बुद्धिहीन तनु जानिके, सुमिरौ पवन-कुमार ।",
            "बल बुद्धि विद्या देहु मोहिं, हरहु कलेश विकार ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 1,
          "lines": [
            "जय हनुमान ज्ञान गुन सागर ।",
            "जय कपीस तिहुँ लोक उजागर ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 2,
          "lines": [
            "राम दूत अतुलित बल धामा ।",
            "अंजनि-पुत्र पवनसुत नामा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 3,
          "lines": [
            "महावीर विक्रम बजरंगी ।",
            "कुमति निवार सुमति के संगी ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 4,
          "lines": [
            "कंचन बरन विराज सुबेसा ।",
            "कानन कुंडल कुंचित केसा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 5,
          "lines": [
            "हाथ बज्र औ ध्वजा बिराजै ।",
            "काँधे मूँज जनेउ साजै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 6,
          "lines": [
            "शंकर सुवन केसरीनंदन ।",
            "तेज प्रताप महा जग बंदन ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 7,
          "lines": [
            "विद्यावान गुनी अति चातुर ।",
            "राम काज करिबे को आतुर ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 8,
          "lines": [
            "प्रभु चरित्र सुनिबे को रसिया ।",
            "राम लखन सीता मन बसिया ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 9,
          "lines": [
            "सूक्ष्म रूप धरि सियहिं दिखावा ।",
            "विकट रूप धरि लंक जरावा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 10,
          "lines": [
            "भीम रूप धरि असुर संहारे ।",
            "रामचंद्र के काज सँवारे ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 11,
          "lines": [
            "लाये सजीवन लखन जियाये ।",
            "श्री रघुबीर हरषि उर लाये ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 12,
          "lines": [
            "रघुपति कीन्ही बहुत बड़ाई ।",
            "तुम मम प्रिय भरतहि सम भाई ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 13,
          "lines": [
            "सहस बदन तुम्हरो जस गावैं ।",
            "अस कहि श्रीपति कण्ठ लगावैं ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 14,
          "lines": [
            "सनकादिक ब्रह्मादि मुनीसा ।",
            "नारद सारद सहित अहीसा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 15,
          "lines": [
            "जम कुबेर दिगपाल जहाँ ते ।",
            "कवि कोविद कहि सके कहाँ ते ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 16,
          "lines": [
            "तुम उपकार सुग्रीवहिं कीन्हा ।",
            "राम मिलाय राजपद दीन्हा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 17,
          "lines": [
            "तुम्हरो मंत्र विभीषण माना ।",
            "लंकेश्वर भए सब जग जाना ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 18,
          "lines": [
            "युग सहस्त्र योजन पर भानू ।",
            "लील्यो ताहि मधुर फल जानू ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 19,
          "lines": [
            "प्रभु मुद्रिका मेलि मुख माहीं ।",
            "जलधि लाँघि गये अचरज नाहीं ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 20,
          "lines": [
            "दुर्गम काज जगत के जेते ।",
            "सुगम अनुग्रह तुम्हरे तेते ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 21,
          "lines": [
            "राम दुआरे तुम रखवारे ।",
            "होत न आज्ञा बिनु पैसारे ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 22,
          "lines": [
            "सब सुख लहैं तुम्हारी शरना ।",
            "तुम रक्षक काहू को डरना ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 23,
          "lines": [
            "आपन तेज सम्हारो आपै ।",
            "तीनों लोक हाँक ते काँपै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 24,
          "lines": [
            "भूत पिशाच निकट नहिं आवै ।",
            "महाबीर जब नाम सुनावै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 25,
          "lines": [
            "नासै रोग हरै सब पीरा ।",
            "जपत निरंतर हनुमत बीरा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 26,
          "lines": [
            "संकट से हनुमान छुड़ावै ।",
            "मन क्रम बचन ध्यान जो लावै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 27,
          "lines": [
            "सब पर राम तपस्वी राजा ।",
            "तिन के काज सकल तुम साजा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 28,
          "lines": [
            "और मनोरथ जो कोई लावै ।",
            "सोइ अमित जीवन फल पावै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 29,
          "lines": [
            "चारों जुग परताप तुम्हारा ।",
            "है परसिद्ध जगत उजियारा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 30,
          "lines": [
            "साधु संत के तुम रखवारे ।",
            "असुर निकंदन राम दुलारे ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 31,
          "lines": [
            "अष्ट सिद्धि नौ निधि के दाता ।",
            "अस बर दीन जानकी माता ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 32,
          "lines": [
            "राम रसायन तुम्हरे पासा ।",
            "सदा रहो रघुपति के दासा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 33,
          "lines": [
            "तुम्हरे भजन राम को पावै ।",
            "जनम जनम के दुख बिसरावै ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 34,
          "lines": [
            "अन्त काल रघुबर पुर जाई ।",
            "जहाँ जन्म हरिभक्त कहाई ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 35,
          "lines": [
            "और देवता चित्त न धरई ।",
            "हनुमत सेइ सर्ब सुख करई ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 36,
          "lines": [
            "संकट कटै मिटै सब पीरा ।",
            "जो सुमिरै हनुमत बलबीरा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 37,
          "lines": [
            "जय जय जय हनुमान गोसाईं ।",
            "कृपा करहु गुरुदेव की नाईं ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 38,
          "lines": [
            "जो सत बार पाठ कर कोई ।",
            "छूटहिं बंदि महा सुख होई ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 39,
          "lines": [
            "जो यह पढ़ै हनुमान चालीसा ।",
            "होय सिद्धि साखी गौरीसा ।।"
          ]
        },
        {
          "type": "chaupai",
          "number": 40,
          "lines": [
            "तुलसीदास सदा हरि चेरा ।",
            "कीजै नाथ हृदय मँह डेरा ।।"
          ]
        },
        {
          "type": "doha",
          "number": 3,
          "lines": [
            "पवनतनय संकट हरन, मंगल मूरति रूप ।",
            "राम लखन सीता सहित, हृदय बसहु सुर भूप ।।"
          ]
        }
      ]
    }
  ]
}