      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "भजे व्रजैक मण्डनम्, समस्त पाप खण्डनम्,",
            "स्वभक्त चित्त रञ्जनम्, सदैव नन्द नन्दनम्,",
            "सुपिञ्छ गुच्छ मस्तकम्, सुनाद वेणु हस्तकम्,",
            "अनङ्ग रङ्ग सागरम्, नमामि कृष्ण नागरम् ॥ १ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "मनोज गर्व मोचनम् विशाल लोल लोचनम्,",
            "विधूत गोप शोचनम् नमामि पद्म लोचनम्,",
            "करारविन्द भूधरम् स्मितावलोक सुन्दरम्,",
            "महेन्द्र मान दारणम्, नमामि कृष्ण वारणम् ॥ २ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "कदम्ब सून कुण्डलम् सुचारु गण्ड मण्डलम्,",
            "व्रजान्गनैक वल्लभम् नमामि कृष्ण दुर्लभम्,",
            "यशोदया समोदया सगोपया सनन्दया,",
            "युतं सुखैक दायकम् नमामि गोप नायकम् ॥ ३ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "सदैव पाद पङ्कजम् मदीय मानसे निजम्,",
            "दधानमुत्तमालकम् नमामि नन्द बालकम्,",
            "समस्त दोष शोषणम्, समस्त लोक पोषणम्,",
            "समस्त गोप मानसम्, नमामि नन्द लालसम् ॥ ४ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "भुवो भरावतारकम् भवाब्धि कर्ण धारकम्,",
            "यशोमती किशोरकम् नमामि चित्त चोरकम्,",
            "दृगन्त कान्त भङ्गिनम् सदा सदालसंगिनम्,",
            "दिने दिने नवम् नवम् नमामि नन्द संभवम् ॥ ५ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 6,
          "lines": [
            "गुणाकरम् सुखाकरम् कृपाकरम् कृपापरम्,",
            "सुरद्विषन्निकन्दनम् नमामि गोप नन्दनम्,",
            "नवीन गोप नागरम् नवीन केलि लम्पटम्,",
            "नमामि मेघ सुन्दरम् तथित प्रभालसत्पतम् ॥ ६ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 7,
          "lines": [
            "समस्त गोप नन्दनम् हृदम्बुजैक मोदनम्,",
            "नमामि कुञ्ज मध्यगम् प्रसन्न भानु शोभनम्,",
            "निकाम कामदायकम् दृगन्त चारु सायकम्,",
            "रसाल वेणु गायकम् नमामि कुञ्ज नायकम् ॥ ७ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 8,
          "lines": [
            "विदग्ध गोपिका मनो मनोज्ञा तल्पशायिनम्,",
            "नमामि कुञ्ज कानने प्रवृद्ध वह्नि पायिनम्,",
            "किशोर कान्ति रञ्जितम् द्रुगञ्जनम् सुशोभितम्,",
            "गजेन्द्र मोक्ष कारिणम् नमामि श्रीविहारिणम् ॥ ८ ॥"
          ]
        },
        {
          "type": "verse",
          "number": 9,
          "lines": [
