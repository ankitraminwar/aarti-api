      "searchableText": "पांडुरंग अष्टकम् विठ्ठल पांडुरंग परब्रह्मलिंगं भजे",
      "translations": {
        "hi": {
          "title": "श्री पांडुरंग अष्टकम्",
          "type": "अष्टक",
          "category": "विठ्ठल"
        },
        "en": {
          "title": "Pandurang Ashtakam",
          "type": "Ashtakam",
