      "searchableText": "सरस्वती वंदना या कुन्देन्दु तुषारहारधवला वीणावरदण्डमण्डितकरा शुक्लाम् ब्रह्मविचारसार शारदा",
      "translations": {
        "hi": {
          "title": "सरस्वती वंदना",
          "type": "मंत्र",
          "category": "सरस्वती"
        },
        "en": {
          "title": "Saraswati Vandana",
          "type": "Mantra",
          "category": "Saraswati"
        },
        "mr": {
          "title": "सरस्वती वंदना",
          "type": "मंत्र",
          "category": "सरस्वती"
        }
      },
      "verses": [
        {
          "type": "shlok",
          "number": 1,
          "lines": [
            "या कुन्देन्दु तुषारहारधवला या शुभ्रवस्त्रावृता ।",
            "या वीणावरदण्डमण्डितकरा या श्वेतपद्मासना ।।",
            "या ब्रह्माच्युत शंकरप्रभृतिभिः देवैः सदा वन्दिता ।",
            "सा माम् पातु सरस्वती भगवती निःशेषजाड्यापहा ।।"
          ]
        },
        {
          "type": "shlok",
          "number": 2,
          "lines": [
            "शुक्लाम् ब्रह्मविचारसारपरमामाद्यां जगद्व्यापिनीम् ।",
            "वीणापुस्तकधारिणीमभयदां जाड्यांधकारापहाम् ।।",
            "हस्ते स्फाटिकमालिकां विदधतीं पद्मासने संस्थिताम् ।",
            "वन्दे तां परमेश्वरीं भगवतीं बुद्धिप्रदां शारदाम् ।।"
          ]
        }
