      "searchableText": "अगजानन पद्माकं शुक्लांबरधरं विष्णुं वक्रतुण्ड महाकाय गजाननं भूतगणाधिसेवितं गणपति स्तोत्रम्",
      "translations": {
        "hi": {
          "title": "गणपति स्तोत्रम्",
          "type": "मंत्र",
          "category": "श्री गणेश"
        },
        "en": {
          "title": "Ganapati Stotram",
          "type": "Mantra",
          "category": "Shri Ganesh"
        },
        "mr": {
          "title": "गणपति स्तोत्रम्",
          "type": "मंत्र",
          "category": "श्री गणेश"
        }
      },
      "verses": [
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "अगजानन-पद्माकं गजाननम्-अहर्निशम्।",
            "अनेकदंतं भक्तानाम् एकदन्तम्-उपास्महे ॥१॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "शुक्लांबरधरं विष्णुं शशिवर्णं चतुर्भुजम्।",
            "प्रसन्नवदनं ध्यायेत् सर्व-विघ्नोपशान्तये ॥२॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "वक्रतुण्ड महाकाय कोटिसूर्य-समप्रभ ।",
            "अविघ्नं कुरु मे देव सर्व-कार्येषु सर्वदा ॥३॥"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "गजाननं भूत-गणाधिसेवितं",
            "कपित्थ-जम्बू-फलसार-भक्षकम्।",
            "उमासुतं शोकविनाश-कारणं",
            "नमामि विघ्नेश्वर-पाद-पङ्कजम्॥४॥"
          ]
        }
      ]
    },
