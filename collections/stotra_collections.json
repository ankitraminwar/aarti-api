        },
        "mr": {
          "title": "श्रीरामरक्षास्तोत्र",
          "type": "स्तोत्र",
          "category": "श्री राम"
        }
      },
      "verses": [
        {
          "type": "verse",
          "number": 0,
          "lines": [
            "श्रीगणेशाय नम: ।",
            "अस्य श्रीरामरक्षास्तोत्रमन्त्रस्य ।",
            "बुधकौशिक ऋषि: ।",
            "श्रीसीतारामचंद्रोदेवता ।",
            "अनुष्टुप् छन्द: ।",
            "सीता शक्ति: ।",
            "श्रीमद्‌हनुमान् कीलकम् ।",
            "श्रीसीतारामचंद्रप्रीत्यर्थे जपे विनियोग: ॥"
          ]
        },
        {
          "type": "verse",
          "number": 0,
          "lines": [
            "॥ अथ ध्यानम् ॥",
            "ध्यायेदाजानुबाहुं धृतशरधनुषं बद्धपद्‌मासनस्थं ।",
            "पीतं वासोवसानं नवकमलदलस्पर्धिनेत्रं प्रसन्नम् ॥",
            "वामाङ्‌कारूढ-सीता-मुखकमल-मिलल्लोचनं नीरदाभं ।",
            "नानालङ्‌कारदीप्तं दधतमुरुजटामण्डनं रामचंद्रम् ॥"
          ]
        },
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "चरितं रघुनाथस्य शतकोटिप्रविस्तरम् ।",
            "एकैकमक्षरं पुंसां महापातकनाशनम् ॥१॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "ध्यात्वा नीलोत्पलश्यामं रामं राजीवलोचनम् ।",
            "जानकीलक्ष्मणोपेतं जटामुकुटमण्डितम् ॥२॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "सासितूणधनुर्बाणपाणिं नक्तं चरान्तकम् ।",
            "स्वलीलया जगत्त्रातुमाविर्भूतमजं विभुम् ॥३॥"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "रामरक्षां पठेत्प्राज्ञ: पापघ्नीं सर्वकामदाम् ।",
            "शिरो मे राघव: पातु भालं दशरथात्मज: ॥४॥"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "कौसल्येयो दृशौ पातु विश्वामित्रप्रिय: श्रुती ।",
            "घ्राणं पातु मखत्राता मुखं सौमित्रिवत्सल: ॥५॥"
          ]
        },
        {
          "type": "verse",
          "number": 6,
          "lines": [
            "जिव्हां विद्यानिधि: पातु कण्ठं भरतवंदित: ।",
            "स्कन्धौ दिव्यायुध: पातु भुजौ भग्नेशकार्मुक: ॥६॥"
          ]
        },
        {
          "type": "verse",
          "number": 7,
          "lines": [
            "करौ सीतापति: पातु हृदयं जामदग्न्यजित् ।",
            "मध्यं पातु खरध्वंसी नाभिं जाम्बवदाश्रय: ॥७॥"
          ]
        },
        {
          "type": "verse",
          "number": 8,
          "lines": [
            "सुग्रीवेश: कटी पातु सक्थिनी हनुमत्प्रभु: ।",
            "ऊरू रघुत्तम: पातु रक्ष:कुलविनाशकृत् ॥८॥"
          ]
        },
        {
          "type": "verse",
          "number": 9,
          "lines": [
            "जानुनी सेतुकृत्पातु जङ्‌घे दशमुखान्तक: ।",
            "पादौ बिभीषणश्रीद: पातु रामोऽखिलं वपु: ॥९॥"
          ]
        },
        {
          "type": "verse",
          "number": 10,
          "lines": [
            "एतां रामबलोपेतां रक्षां य: सुकृती पठॆत् ।",
            "स चिरायु: सुखी पुत्री विजयी विनयी भवेत् ॥१०॥"
          ]
        },
        {
          "type": "verse",
          "number": 11,
          "lines": [
            "पातालभूतलव्योम चारिणश्छद्‌मचारिण: ।",
            "न द्र्ष्टुमपि शक्तास्ते रक्षितं रामनामभि: ॥११॥"
          ]
        },
        {
          "type": "verse",
          "number": 12,
          "lines": [
            "रामेति रामभद्रेति रामचंद्रेति वा स्मरन् ।",
            "नरो न लिप्यते पापै भुक्तिं मुक्तिं च विन्दति ॥१२॥"
          ]
        },
        {
          "type": "verse",
          "number": 13,
          "lines": [
            "जगज्जेत्रैकमन्त्रेण रामनाम्नाभिरक्षितम् ।",
            "य: कण्ठे धारयेत्तस्य करस्था: सर्वसिद्धय: ॥१३॥"
          ]
        },
        {
          "type": "verse",
          "number": 14,
          "lines": [
            "वज्रपंजरनामेदं यो रामकवचं स्मरेत् ।",
            "अव्याहताज्ञ: सर्वत्र लभते जयमंगलम् ॥१४॥"
          ]
        },
        {
          "type": "verse",
          "number": 15,
          "lines": [
            "आदिष्टवान् यथा स्वप्ने रामरक्षामिमां हर: ।",
            "तथा लिखितवान् प्रात: प्रबुद्धो बुधकौशिक: ॥१५॥"
          ]
        },
        {
          "type": "verse",
          "number": 16,
          "lines": [
            "आराम: कल्पवृक्षाणां विराम: सकलापदाम् ।",
            "अभिरामस्त्रिलोकानां राम: श्रीमान् स न: प्रभु: ॥१६॥"
          ]
        },
        {
          "type": "verse",
          "number": 17,
          "lines": [
            "तरुणौ रूपसंपन्नौ सुकुमारौ महाबलौ ।",
            "पुण्डरीकविशालाक्षौ चीरकृष्णाजिनाम्बरौ ॥१७॥"
          ]
        },
        {
          "type": "verse",
          "number": 18,
          "lines": [
            "फलमूलशिनौ दान्तौ तापसौ ब्रह्मचारिणौ ।",
            "पुत्रौ दशरथस्यैतौ भ्रातरौ रामलक्ष्मणौ ॥१८॥"
          ]
        },
        {
          "type": "verse",
          "number": 19,
          "lines": [
            "शरण्यौ सर्वसत्वानां श्रेष्ठौ सर्वधनुष्मताम् ।",
            "रक्ष:कुलनिहन्तारौ त्रायेतां नो रघुत्तमौ ॥१९॥"
          ]
        },
        {
          "type": "verse",
          "number": 20,
          "lines": [
            "आत्तसज्जधनुषा विषुस्पृशा वक्षया शुगनिषङ्ग सङ्गिनौ ।",
            "रक्षणाय मम रामलक्ष्मणावग्रत: पथि सदैव गच्छताम् ॥२०॥"
          ]
        },
        {
          "type": "verse",
          "number": 21,
          "lines": [
            "संनद्ध: कवची खड्गी चापबाणधरो युवा ।",
            "गच्छन् मनोरथोऽस्माकं राम: पातु सलक्ष्मण: ॥२१॥"
          ]
        },
        {
          "type": "verse",
          "number": 22,
          "lines": [
            "रामो दाशरथि: शूरो लक्ष्मणानुचरो बली ।",
            "काकुत्स्थ: पुरुष: पूर्ण: कौसल्येयो रघुत्तम: ॥२२॥"
          ]
        },
        {
          "type": "verse",
          "number": 23,
          "lines": [
            "वेदान्तवेद्यो यज्ञेश: पुराणपुरुषोत्तम: ।",
            "जानकीवल्लभ: श्रीमानप्रमेयपराक्रम: ॥२३॥"
          ]
        },
        {
          "type": "verse",
          "number": 24,
          "lines": [
            "इत्येतानि जपेन्नित्यं मद्भक्त: श्रद्धयान्वित: ।",
            "अश्वमेधाधिकं पुण्यं संप्राप्नोति न संशय: ॥२४॥"
          ]
        },
        {
          "type": "verse",
          "number": 25,
          "lines": [
            "रामं दूर्वादलश्यामं पद्माक्षं पीतवाससम् ।",
            "स्तुवन्ति नामभिर्दिव्यैर्न ते संसारिणो नर: ॥२५॥"
          ]
        },
        {
          "type": "verse",
          "number": 26,
          "lines": [
            "रामं लक्ष्मणपूर्वजं रघुवरं सीतापतिं सुंदरम् ।",
            "काकुत्स्थं करुणार्णवं गुणनिधिं विप्रप्रियं धार्मिकम् ।",
            "राजेन्द्रं सत्यसंधं दशरथनयं श्यामलं शान्तमूर्तिम् ।",
            "वन्दे लोकभिरामं रघुकुलतिलकं राघवं रावणारिम् ॥२६॥"
          ]
        },
        {
          "type": "verse",
          "number": 27,
          "lines": [
            "रामाय रामभद्राय रामचंद्राय वेधसे ।",
            "रघुनाथाय नाथाय सीताया: पतये नम: ॥२७॥"
          ]
        },
        {
          "type": "verse",
          "number": 28,
          "lines": [
            "श्रीराम राम रघुनन्दन राम राम ।",
            "श्रीराम राम भरताग्रज राम राम ।",
            "श्रीराम राम रणकर्कश राम राम ।",
            "श्रीराम राम शरणं भव राम राम ॥२८॥"
          ]
        },
        {
          "type": "verse",
          "number": 29,
          "lines": [
            "श्रीरामचन्द्रचरणौ मनसा स्मरामि ।",
            "श्रीरामचन्द्रचरणौ वचसा गृणामि ।",
            "श्रीरामचन्द्रचरणौ शिरसा नमामि ।",
            "श्रीरामचन्द्रचरणौ शरणं प्रपद्ये ॥२९॥"
          ]
        },
        {
          "type": "verse",
          "number": 30,
          "lines": [
            "माता रामो मत्पिता रामचन्द्र: ।",
            "स्वामी रामो मत्सखा रामचन्द्र: ।",
            "सर्वस्वं मे रामचन्द्रो दयालुर् ।",
            "नान्यं जाने नैव जाने न जाने ॥३०॥"
          ]
        },
        {
          "type": "verse",
          "number": 31,
          "lines": [
            "दक्षिणे लक्ष्मणो यस्य वामे च जनकात्मजा ।",
            "पुरतो मारुतिर्यस्य तं वन्दे रघुनंदनम् ॥३१॥"
          ]
        },
        {
          "type": "verse",
          "number": 32,
          "lines": [
            "लोकाभिरामं रणरङ्गधीरं राजीवनेत्रं रघुवंशनाथम् ।",
            "कारुण्यरूपं करुणाकरन्तं श्रीरामचन्द्रं शरणं प्रपद्ये ॥३२॥"
          ]
        },
        {
          "type": "verse",
          "number": 33,
          "lines": [
            "मनोजवं मारुततुल्यवेगं जितेन्द्रियं बुद्धिमतां वरिष्ठम् ।",
            "वातात्मजं वानरयूथमुख्यं श्रीरामदूतं शरणं प्रपद्ये ॥३३॥"
          ]
        },
        {
          "type": "verse",
          "number": 34,
          "lines": [
            "कूजन्तं रामरामेति मधुरं मधुराक्षरम् ।",
            "आरुह्य कविताशाखां वन्दे वाल्मीकिकोकिलम् ॥३४॥"
          ]
        },
        {
          "type": "verse",
          "number": 35,
          "lines": [
            "आपदामपहर्तारं दातारं सर्वसंपदाम् ।",
            "लोकाभिरामं श्रीरामं भूयो भूयो नमाम्यहम् ॥३५॥"
          ]
        },
        {
          "type": "verse",
          "number": 36,
          "lines": [
            "भर्जनं भवबीजानामर्जनं सुखसंपदाम् ।",
            "तर्जनं यमदूतानां रामरामेति गर्जनम् ॥३६॥"
          ]
        },
        {
          "type": "verse",
          "number": 37,
          "lines": [
            "रामो राजमणि: सदा विजयते रामं रमेशं भजे ।",
            "रामेणाभिहता निशाचरचमू रामाय तस्मै नम: ।",
            "रामान्नास्ति परायणं परतरं रामस्य दासोऽस्म्यहम् ।",
            "रामे चित्तलय: सदा भवतु मे भो राम मामुद्धर ॥३७॥"
          ]
        },
        {
          "type": "verse",
          "number": 38,
          "lines": [
            "राम रामेति रामेति रमे रामे मनोरमे ।",
            "सहस्रनाम तत्तुल्यं रामनाम वरानने ॥३८॥"
          ]
        },
        {
          "type": "verse",
          "number": 39,
          "lines": [
            "इति श्रीबुधकौशिकविरचितं श्रीरामरक्षास्तोत्रं संपूर्णम् ॥",
            "॥ श्री सीतारामचंद्रार्पणमस्तु ॥"
          ]
        }
      ]
    },
    {
