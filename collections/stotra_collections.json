          "type": "स्तोत्र",
          "category": "श्री विष्णु"
        }
      },
      "verses": [
        {
          "type": "invocation",
          "number": 0,
          "lines": [
            "।। श्री व्यंकटेश स्तोत्र ।।",
            "श्री गणेशाय नम: । श्री व्यंकटशाय नम: ।",
            "ॐ नमो जी हेरंबा । सकळादि तू प्रारंभा ।",
            "आठवूनी तुझी स्वरूपशोभा । वंदन भावे करीतसे"
          ]
        },
        {
          "type": "verse",
          "number": 1,
          "lines": [
            "नमन माझे हंसवाहिनी । वाग्वरदे विलासिनी ।",
            "ग्रंथ वदावया निरुपणी । भावार्थखाणी जयामाजी"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "नमन माझे गुरुवर्या । प्रकाशरूपा तू स्वामिया ।",
            "स्फूर्ति द्यावी ग्रंथ वदावया । जेणे श्रोतया सुख वाटे"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "नमन माझे संतसज्जना । आणि योगिया मुनिजना ।",
            "सकळ श्रोतया साधुजना । नमन माझे साष्टांगी"
          ]
        },
        {
          "type": "verse",
          "number": 4,
          "lines": [
            "ग्रंथ ऐका प्रार्थनाशतक । महादोषांसी दाहक ।",
            "तोषुनिया वैकुंठनायक । मनोरथ पूर्ण करील"
          ]
        },
        {
          "type": "verse",
          "number": 5,
          "lines": [
            "जयजयाजी व्यंकटरमणा । दयासागरा परिपूर्णा ।",
            "परंज्योती प्रकाशगहना । करितो प्रार्थना श्रवण कीजे"
          ]
        },
        {
          "type": "verse",
          "number": 6,
          "lines": [
            "जननीपरी त्वां पाळिले । पितयापरी त्वां सांभाळिले ।",
            "सकळ संकटांपासुनि रक्षिले । पूर्ण दिधले प्रेमसुख"
          ]
        },
        {
          "type": "verse",
          "number": 7,
          "lines": [
            "हे अलोलिक जरी मानावे । तरी जग हे सृजिले आघवे ।",
            "जनक जननीपण स्वभावें । सहज आले अंगासी"
          ]
        },
        {
          "type": "verse",
          "number": 8,
          "lines": [
            "दीननाथा प्रेमासाठी । भक्त रक्षिले संकटी ।",
            "प्रेम दिधले अपूर्व गोष्टी । भजनासाठी भक्तांच्या"
          ]
        },
        {
          "type": "verse",
          "number": 9,
          "lines": [
            "आता परिसावी विज्ञापना । कृपाळुवा लक्ष्मीरमणा ।",
            "मज घालोनि गर्भाधाना । अलोलिक रचना दाखविली"
          ]
        },
        {
          "type": "verse",
          "number": 10,
          "lines": [
            "तुज न जाणता झालो कष्टी । आता दृढ तुझे पायी घातली मिठी ।",
            "कृपाळुवा जगजेठी । अपराध पोटी घाली माझे"
          ]
        },
        {
          "type": "verse",
          "number": 11,
          "lines": [
            "माझिया अपराधांच्या राशी । भेदोनी गेल्या गगनासी ।",
            "दयावंता हृषीकेशी । आपुल्या ब्रीदासी सत्य करी"
          ]
        },
        {
          "type": "verse",
          "number": 12,
          "lines": [
            "पुत्राचे सहस्र अपराध । माता काय मानी तयाचा खेद ।",
            "तेवी तू कृपाळू गोविंद । मायबाप मजलागी"
          ]
        },
        {
          "type": "verse",
          "number": 13,
          "lines": [
            "उडदांमाजी काळेगोरे । काय निवडावे निवडणारे ।",
            "कुचलिया वृक्षांची फळे । मधुर कोठोनी असतील"
          ]
        },
        {
          "type": "verse",
          "number": 14,
          "lines": [
            "अराटीलागी मृदुता । कोठोनी असेल कृपावंता ।",
            "पाषाणासी गुल्मलता । कैशियापरी फुटतील"
          ]
        },
        {
          "type": "verse",
          "number": 15,
          "lines": [
            "आपादमस्तकावरी अन्यायी । परी तुझे पदरी पडिलो पाही ।",
            "आता रक्षण नाना उपायी । करणे तुज उचित"
          ]
        },
        {
          "type": "verse",
          "number": 16,
          "lines": [
            "समर्थांचे घरीचे श्र्वान । त्यासी सर्वही देती मान ।",
            "तैसा तुझा म्हणवितो दीन । हा अपमान कवणाचा"
          ]
        },
        {
          "type": "verse",
          "number": 17,
          "lines": [
            "लक्ष्मी तुझे पायांतळी । आम्ही भिक्षेसी घालोनी झोळी ।",
            "येणे तुझी ब्रीदावळी । कैसी राहील गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 18,
          "lines": [
            "कुबेर तुझा भांडारी । आम्हां फिरविसी दारोदारी ।",
            "यात पुरुषार्थ मुरारी । काय तुजला पै आला"
          ]
        },
        {
          "type": "verse",
          "number": 19,
          "lines": [
            "द्रौपदीसी वस्त्रे अनंता । देत होतासी भाग्यवंता ।",
            "आम्हांलागी कृपणता । कोठोनी आणिली गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 20,
          "lines": [
            "मावेची करुनी द्रौपदी सती । अन्ने पुरविली मध्यराती ।",
            "ऋषीश्र्वरांच्या बैसल्या पंक्ती । तृप्त केल्या क्षणमात्रे"
          ]
        },
        {
          "type": "verse",
          "number": 21,
          "lines": [
            "अन्नासाठी दाही दिशा । आम्हां फिरविसी जगदीशा ।",
            "कृपाळुवा परमपुरुषा । करुणा कैशी तुज न ये"
          ]
        },
        {
          "type": "verse",
          "number": 22,
          "lines": [
            "अंगीकारी या शिरोमणि । तुज प्रार्थितो मधुर वचनी ।",
            "अंगीकार केलिया झणी । मज हातींचे न सोडावे"
          ]
        },
        {
          "type": "verse",
          "number": 23,
          "lines": [
            "समुद्रे अंगीकारीला वडवानळ । तेणे अंतरी होतसे विहवळ ।",
            "ऐसे असोनी सर्वकाळ । अंतरी साठविला तयाने"
          ]
        },
        {
          "type": "verse",
          "number": 24,
          "lines": [
            "कूर्मे पृथ्वीचा घेतला भार । तेणे सोडीला नाही बडिवार ।",
            "एवढा ब्रम्हांडगोळ थोर । त्याचा अंगीकार पै केला"
          ]
        },
        {
          "type": "verse",
          "number": 25,
          "lines": [
            "शंकरे धरिले हाळाहळा । तेणे नीळवर्ण झाला गळा ।",
            "परी त्यागिले नाही गोपाळा । भक्तवत्सला गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 26,
          "lines": [
            "माझ्या अपराधांच्या परी । वर्णिता शिणली वैखरी ।",
            "दृष्ट पतीत दुराचारी । अधमाहुनि अधम"
          ]
        },
        {
          "type": "verse",
          "number": 27,
          "lines": [
            "विषयासक्त मंदमति आळशी । कृपण कुव्यसनी मलिन मानसी ।",
            "सदा सर्वकाळ सज्जनांशी । द्रोह करी सर्वदा"
          ]
        },
        {
          "type": "verse",
          "number": 28,
          "lines": [
            "वचनोक्ति नाही मधुर । अत्यंत जनांसी निष्ठुर ।",
            "सकळ पामरांमाजी पामर । व्यर्थ बडिवार जगी वाजे"
          ]
        },
        {
          "type": "verse",
          "number": 29,
          "lines": [
            "काम क्रोध मद मत्सर । हे शरीर त्यांचे बिढार ।",
            "कामकल्पनेसी थार । दृढ येथे केला असे"
          ]
        },
        {
          "type": "verse",
          "number": 30,
          "lines": [
            "अठरा भार वनस्पतींची लेखणी । समुद्र भरला मषीकरुनी ।",
            "माझे अवगुण लिहिता धरणी । तरी लिहिले न जाती"
          ]
        },
        {
          "type": "verse",
          "number": 31,
          "lines": [
            "ऐसा पतित मी खरा । परी तू पतितपावन शारद्गधरा ।",
            "तुवा अंगीकार केलिया गदाधरा । कोण दोषगुण गणील"
          ]
        },
        {
          "type": "verse",
          "number": 32,
          "lines": [
            "नीच रतली रायाशी । तिसी कोण म्हणेल दासी ।",
            "लोह लागता परिसासी । पूर्वास्थिती मग कैंची"
          ]
        },
        {
          "type": "verse",
          "number": 33,
          "lines": [
            "गावीचे होते लेंडवोहळ । गंगेसी मिळता गंगाजळ ।",
            "कागविष्ठेचे झाले पिंपळ । तयांसी निद्य कोण म्हणे"
          ]
        },
        {
          "type": "verse",
          "number": 34,
          "lines": [
            "तसा कुजाति मी अमंगळ । परी तुझा म्हणवितो केवळ ।",
            "कन्या देऊनिया कुळ । मग काय विचारावे"
          ]
        },
        {
          "type": "verse",
          "number": 35,
          "lines": [
            "जाणत असता अपराधी नर । तरी का केला अंगीकार ।",
            "अंगीकारावरी अव्हेर । समर्थे न केला पाहिजे"
          ]
        },
        {
          "type": "verse",
          "number": 36,
          "lines": [
            "धाव पाव रें गोविंदा । हाती घेवोनिया गदा ।",
            "करी माझ्या कर्माचा चेंदा । सच्चिदानंदा श्रीहरी"
          ]
        },
        {
          "type": "verse",
          "number": 37,
          "lines": [
            "तुझिया नामाची अपरिमित शक्ति । तेथें माझी पापे किती ।",
            "कृपाळुवा लक्ष्मीपती । बरवे चित्ती विचारी"
          ]
        },
        {
          "type": "verse",
          "number": 38,
          "lines": [
            "तुझे नाम पतितपावन । तुझे नाम कलिमलदहन ।",
            "तुझे नाम भवतारण । संकटनाशन नाम तुझे"
          ]
        },
        {
          "type": "verse",
          "number": 39,
          "lines": [
            "आता प्रार्थना ऐके कमळापती । तुझे नामी राहे माझी मती ।",
            "हेचि मागतो पुढतपुढती । परंज्योती व्यंकटेशा"
          ]
        },
        {
          "type": "verse",
          "number": 40,
          "lines": [
            "तू अनंत तुझी अनंत नामे । तयांमाजी अति सुगमे ।",
            "ती मी अल्पमति प्रेमे । स्मरूनी प्रार्थना करीतसे"
          ]
        },
        {
          "type": "verse",
          "number": 41,
          "lines": [
            "श्रीव्यंकटेशा वासुदेवा । प्रद्युमन्ना अनंता केशवा ।",
            "संकर्षणा श्रीधरा माधवा । नारायणा आदिमूर्ते"
          ]
        },
        {
          "type": "verse",
          "number": 42,
          "lines": [
            "पद्मनाभा दामोदरा । प्रकाशगहना परात्परा ।",
            "आदिअनादि विश्वंभरा । जगदुद्धारा जगदीशा"
          ]
        },
        {
          "type": "verse",
          "number": 43,
          "lines": [
            "कृष्णा विष्णो हृषीकेशा । अनिरुद्धा पुरुषोत्तमा परेशा ।",
            "नृसिंह वामन भार्गवेशा । बौद्ध कलंकी निजमूर्ती"
          ]
        },
        {
          "type": "verse",
          "number": 44,
          "lines": [
            "अनाथरक्षका आदिपुरुषा । पूर्णब्रम्ह सनातन निर्दोषा ।",
            "सकळ मंगळ मंगळाधीशा । सज्जनजीवना सुखमूर्ते"
          ]
        },
        {
          "type": "verse",
          "number": 45,
          "lines": [
            "गुणातीता गुणज्ञा । निजबोधरूपा निमग्ना ।",
            "शुद्ध सात्विका सुज्ञा । गुणप्राज्ञा परमेश्वरा"
          ]
        },
        {
          "type": "verse",
          "number": 46,
          "lines": [
            "श्रीनिधीश्रीवत्सलांछन धरा । भयकृद्भयनाशना गिरीधरा ।",
            "दृष्टदैत्यसंहारकरा । वीर सुखकरा तू एक"
          ]
        },
        {
          "type": "verse",
          "number": 47,
          "lines": [
            "निखिल निरंजन निर्विकारा । विवेकखाणी- वैरागरा ।",
            "मधुमुरदैत्यसंहारकरा । असुरमर्दना उग्रमुर्ते"
          ]
        },
        {
          "type": "verse",
          "number": 48,
          "lines": [
            "शंखचक्रगदाधरा । गरुडवाहना भक्तप्रियकरा ।",
            "गोपीमनरंजना सुखकरा । अखंडित स्वभावे"
          ]
        },
        {
          "type": "verse",
          "number": 49,
          "lines": [
            "नानानाटक सूत्रधारिया । जगद्व्यापका जगद्वर्या ।",
            "कृपासमुद्रा करुणालया । मुनिजनध्येया मूळमूर्ति"
          ]
        },
        {
          "type": "verse",
          "number": 50,
          "lines": [
            "शेषशयना सार्वभौमा । वैकुंठवासिया निरुपमा ।",
            "भक्तकैवारिया गुणधामा । पाव आम्हां ये समयी"
          ]
        },
        {
          "type": "verse",
          "number": 51,
          "lines": [
            "ऐसी प्रार्थना करुनी देवीदास । अंतरी आठविला श्रीव्यंकटेश ।",
            "स्मरता हृदयी प्रकटला ईश । त्या सुखासी पार नाही"
          ]
        },
        {
          "type": "verse",
          "number": 52,
          "lines": [
            "हृदयी आविर्भवली मूर्ति । त्या सुखाची अलोलिक स्थिती ।",
            "आपुले आपण श्रीपती । वाचेहाती वदवीतसे"
          ]
        },
        {
          "type": "verse",
          "number": 53,
          "lines": [
            "ते स्वरूप अत्यंत सुंदर । श्रोती श्रवण कीजे सादर ।",
            "सावळी तनु सुकुमार । कुंकुमाकार पादपद्मे"
          ]
        },
        {
          "type": "verse",
          "number": 54,
          "lines": [
            "सुरेख सरळ अंगोळिका । नखे जैसी चंद्ररेखा ।",
            "घोटीव सुनीळ अपूर्व देखा । इंद्रनिळाचियेपरी"
          ]
        },
        {
          "type": "verse",
          "number": 55,
          "lines": [
            "चरणी वाळे घागरिया । वाकी वरत्या गुजरिया ।",
            "सरळ सुंदर पोटरिया । कर्दळीस्तंभाचियेपरी"
          ]
        },
        {
          "type": "verse",
          "number": 56,
          "lines": [
            "गुडघे मांडिया जानुस्थळ । कटितटि किंकिणी विशाळ ।",
            "खालते विश्वंउत्पत्तिस्थळ । वरी झळाळे सोनसळा"
          ]
        },
        {
          "type": "verse",
          "number": 57,
          "lines": [
            "कटीवरते नाभिस्थान । जेथोनि ब्रम्हा झाला उत्पन्न ।",
            "उदरी त्रिवळी शोभे गहन । त्रैलोक्य संपूर्ण जयामाजी"
          ]
        },
        {
          "type": "verse",
          "number": 58,
          "lines": [
            "वक्ष:स्थळी शोभे पदक । पाहोनी चंद्रमा अधोमुख ।",
            "वैजयंती करी लखलख । विद्युल्लतेचियेपरी"
          ]
        },
        {
          "type": "verse",
          "number": 59,
          "lines": [
            "हृदयी श्रीवत्सलांछन । भूषण मिरवी श्रीभगवान ।",
            "तयावरते कंठस्थान । जयासी मुनिजन अवलोकिती"
          ]
        },
        {
          "type": "verse",
          "number": 60,
          "lines": [
            "उभय बाहुदंड सरळ । नखे चंद्रापरीस तेजाळ ।",
            "शोभती दोन्ही करकमळ । रातोत्पलाचियेपरी"
          ]
        },
        {
          "type": "verse",
          "number": 61,
          "lines": [
            "मनगटी विराजती कंकणे । बाहुवटी बाहुभूषणे ।",
            "कंठी लेइली आभरणे । सूर्यकिरणे उगवली"
          ]
        },
        {
          "type": "verse",
          "number": 62,
          "lines": [
            "कंठावरुते मुखकमळ । हनुवटी अत्यंत सुनीळ ।",
            "मुखचंद्रमा अति निर्मळ । भक्तस्नेहाळ गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 63,
          "lines": [
            "दोन्ही अधरांमाजी दंतपंक्ती । जिव्हा जैसी लावण्यज्योती ।",
            "अधरामृतप्राप्तीची गती । ते सुख जाणे लक्ष्मी"
          ]
        },
        {
          "type": "verse",
          "number": 64,
          "lines": [
            "सरळ सुंदर नासिक । जेथे पवनासी झाले सुख ।",
            "गंडस्थळीचे तेज अधिक । लखलखीत दोन्ही भागी"
          ]
        },
        {
          "type": "verse",
          "number": 65,
          "lines": [
            "त्रिभुवनीचे तेज एकटवले । बरवेपण शिगेसी आले ।",
            "दोन्ही पातयांनी धरिले । तेज नेत्र श्रीहरीचे"
          ]
        },
        {
          "type": "verse",
          "number": 66,
          "lines": [
            "व्यंकटा भृकुटिया सुनीळा । कर्णद्वयाची अभिनव लीळा ।",
            "कुंडलांच्या फाकती कळा । तो सुखसोहळा अलोलिक"
          ]
        },
        {
          "type": "verse",
          "number": 67,
          "lines": [
            "भाळ विशाळ सुरेख । वरती शोभे कस्तूरीटिळक ।",
            "केश कुरळ अलोलिक । मस्तकावरी शोभती"
          ]
        },
        {
          "type": "verse",
          "number": 68,
          "lines": [
            "मस्तकी मुकुट आणि किरीटी । सभोवती झिळमिळ्याची दाटी ।",
            "त्यावरी मयूरपिच्छांची वेटी ।ऐसा जगजेठी देखिला"
          ]
        },
        {
          "type": "verse",
          "number": 69,
          "lines": [
            "ऐसा तू देवाधिदेव । गुणातीत वासुदेव ।",
            "माझिया भक्तिस्तव । सगुणरूप झालासी"
          ]
        },
        {
          "type": "verse",
          "number": 70,
          "lines": [
            "आता करू तुझी पूजा । जगज्जीवना अधोक्षजा ।",
            "आर्ष भावार्थ हा माझा । तुज अर्पण केला असे"
          ]
        },
        {
          "type": "verse",
          "number": 71,
          "lines": [
            "करुनी पंचामृतस्नान । शुद्धोधक वरी घालून ।",
            "तुज करू मंगलस्नान । पुरुषसूक्ते करुनिया"
          ]
        },
        {
          "type": "verse",
          "number": 72,
          "lines": [
            "वस्त्रे आणि यज्ञोपवीत । तुजलागी करू प्रीत्यर्थ ।",
            "गंधाक्षता पुष्पे बहुत । तुजलागी समर्पू"
          ]
        },
        {
          "type": "verse",
          "number": 73,
          "lines": [
            "धूप दीप नैवेध्य । फल तांबूल दक्षिणा शुद्ध ।",
            "वस्त्रे भूषणे गोमेद । पद्मरागादिकरून"
          ]
        },
        {
          "type": "verse",
          "number": 74,
          "lines": [
            "भक्तवत्सला गोविंदा । ही पूजा अंगीकारावी परमानंदा ।",
            "नमस्कारुनी पादारविंदा । मग प्रदक्षिणा आरंभिली"
          ]
        },
        {
          "type": "verse",
          "number": 75,
          "lines": [
            "ऐसा षोडशोपचारे भगवंत । यथाविधी पूजिला हृदयात ।",
            "मग प्रार्थना आरंभिली बहुत । वरप्रसाद मागावया"
          ]
        },
        {
          "type": "verse",
          "number": 76,
          "lines": [
            "जयजयाजी श्रुतिशास्त्रआगमा । जयजयाजी गुणातीत परब्रम्हा ।",
            "जयजयाजी हृदयवासिया रामा । जगदुद्धारा जगद्गुरो"
          ]
        },
        {
          "type": "verse",
          "number": 77,
          "lines": [
            "जयजयाजी पंकजाक्षा । जयजयाजी कमळाधीशा ।",
            "जयजयाजी पूर्णपरेशा । अव्यक्तव्यक्ता सुखमूर्ते"
          ]
        },
        {
          "type": "verse",
          "number": 78,
          "lines": [
            "जयजयाजी भक्तरक्षका । जयजयाजी वैकुंठनायका ।",
            "जयजयाजी जगपालका । भक्तांसी सखा तू एक"
          ]
        },
        {
          "type": "verse",
          "number": 79,
          "lines": [
            "जयजयाजी निरंजना । जयजयाजी परात्परगहना ।",
            "जयजयाजी शुन्यातीत निर्गुणा । परिसावी विज्ञापना एक माझी"
          ]
        },
        {
          "type": "verse",
          "number": 80,
          "lines": [
            "मजलागी देई ऐसा वर । जेणे घडेल परोपकार ।",
            "हेचि मागणे साचार । वारंवार प्रार्थितसे"
          ]
        },
        {
          "type": "verse",
          "number": 81,
          "lines": [
            "हा ग्रंथ जो पठण करी । त्यासी दु:ख नसावे संसारी ।",
            "पठणमात्रे चराचरी । विजयी करी जगाते"
          ]
        },
        {
          "type": "verse",
          "number": 82,
          "lines": [
            "लग्नार्थीयाचे व्हावे लग्न । धनार्थियासी व्हावे धन ।",
            "पुत्रार्थियासे मनोरथ पूर्ण । पुत्र देऊनी करावे"
          ]
        },
        {
          "type": "verse",
          "number": 83,
          "lines": [
            "पुत्र विजयी आणि पंडित । शतायुषी भाग्यवंत ।",
            "पितृसेवेसी अत्यंत रत । जायचे चित्त सर्वकाळ"
          ]
        },
        {
          "type": "verse",
          "number": 84,
          "lines": [
            "उदार आणि सर्वज्ञ । पुत्र देई भक्तांलागून ।",
            "व्याधिष्ठांची पीडा हरण । तत्काळ कीजे गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 85,
          "lines": [
            "क्षय अपस्मार कुष्ठादिरोग । ग्रंथपठणे सरावा भोग ।",
            "योगाभ्यासियासी योग । पठणमात्रे साधावा"
          ]
        },
        {
          "type": "verse",
          "number": 86,
          "lines": [
            "दरिद्री व्हावा भाग्यवंत । शत्रूचा व्हावा नि:पात ।",
            "सभा व्हावी वश समस्त । ग्रंथपठणेकरुनिया"
          ]
        },
        {
          "type": "verse",
          "number": 87,
          "lines": [
            "विद्यार्थीयासी विद्या व्हावी । युद्धी शस्त्रे न लागावी ।",
            "पठणे जगात कीर्ती व्हावी । साधु साधु म्हणोनिया"
          ]
        },
        {
          "type": "verse",
          "number": 88,
          "lines": [
            "अंती व्हावे मोक्षसाधन । ऐसे प्रार्थनेसी दीजे मन ।",
            "एवढे मागती वरदान । कृपानिधे गोविंदा"
          ]
        },
        {
          "type": "verse",
          "number": 89,
          "lines": [
            "प्रसन्न झाला व्यंकटरमण । देवीदासासी दिधले वरदान ।",
            "ग्रंथाक्षरी माझे वचन । यथार्थ जाण निश्चयेसी"
          ]
        },
        {
          "type": "verse",
          "number": 90,
          "lines": [
            "ग्रंथी धरोनी विश्वास । पठण करील रात्रंदिवस ।",
            "त्यालागी मी जगदीश । क्षण एक न विसंबे"
          ]
        },
        {
          "type": "verse",
          "number": 91,
          "lines": [
            "इच्छा धरुनी करील पठण । त्याचे सांगतो मी प्रमाण ।",
            "सर्व कामनेसी साधन । पठण एक मंडळ"
          ]
        },
        {
          "type": "verse",
          "number": 92,
          "lines": [
            "पुत्रार्थियाने तीन मास । धनार्थियाने एकवीस दिवस ।",
            "कन्यार्थियाने षण्मास । ग्रंथ आदरे वाचवा"
          ]
        },
        {
          "type": "verse",
          "number": 93,
          "lines": [
            "क्षय अपस्मार कुष्ठादिरोग । इत्यादि साधने प्रयोग ।",
            "त्यासी एक मंडळ सांग । पठणे करुनी कार्यसिद्धी"
          ]
        },
        {
          "type": "verse",
          "number": 94,
          "lines": [
            "हे वाक्य माझे नेमस्त । ऐसे बोलिला श्रीभगवंत ।",
            "साच न मानी जयाचे चित्त । त्यासी अध:पात सत्य होय"
          ]
        },
        {
          "type": "verse",
          "number": 95,
          "lines": [
            "विश्वास धरील ग्रंथपठणी । त्यासी कृपा करील चक्रपाणी ।",
            "वर दिधला कृपा करूनि । अनुभवे कळो येईल"
          ]
        },
        {
          "type": "verse",
          "number": 96,
          "lines": [
            "गजेंद्राचिया आकांतासी । कैसा पावला हृषीकेशी ।",
            "प्रल्हादाचिया भावार्थासी । स्तंभातूनि प्रकटला"
          ]
        },
        {
          "type": "verse",
          "number": 97,
          "lines": [
            "वज्रासाठी गोविंदा । गोवर्धन परमानंदा ।",
            "उचलोनिया स्वानंदकंदा । सुखी केलें तये वेळी"
          ]
        },
        {
          "type": "verse",
          "number": 98,
          "lines": [
            "वत्साचेपरी भक्तांसी । मोहे पान्हावे धेनु जैसी ।",
            "मातेच्या स्नेहतुलनेसी । त्याचपरी घडलेसे"
          ]
        },
        {
          "type": "verse",
          "number": 99,
          "lines": [
            "ऐसा तू माझा दातार । भक्तासी घालिसी कृपेची पाखर ।",
            "हा तयाचा निर्धार । अनाथनाथ नाम तुझे"
          ]
        },
        {
          "type": "verse",
          "number": 100,
          "lines": [
            "श्री चैतन्यकृपा अलोकिक । संतोषोनी वैकुंठनायक ।",
            "वर दिधला अलोकिक । जेणे सुख सकळांसी"
          ]
        },
        {
          "type": "verse",
          "number": 101,
          "lines": [
            "हा ग्रंथ लिहिता गोविंद । या वचनी न धरावा भेद ।",
            "हृदयी वसे परमानंद । अनुभवसिद्ध सकळांसी"
          ]
        },
        {
          "type": "verse",
          "number": 102,
          "lines": [
            "या ग्रंथीचा इतिहास । भावे बोलिला विष्णुदास ।",
            "आणिक न लागती सायास । पठणमात्रे कार्यसिद्धी"
          ]
        },
        {
          "type": "verse",
          "number": 103,
          "lines": [
            "पार्वतीस उपदेशी कैलासनायक । पूर्णानंद प्रेमसुख ।",
            "त्याचा पार न जाणती ब्रम्हादिक । मुनि सुरवर विस्मित"
          ]
        },
        {
          "type": "verse",
          "number": 104,
          "lines": [
            "प्रत्यक्ष प्रकटेल वनमाळी । त्रैलोक्य भजत त्रिकाळी ।",
            "ध्याती योगी आणि चंद्रमौळी । शेषाद्रीपर्वती उभा असे"
          ]
        },
        {
          "type": "verse",
          "number": 105,
          "lines": [
            "देवीदास विनवी श्रोतया चतुरा । प्रार्थनाशतक पठण करा ।",
            "जावया मोक्षाचिया मंदिरा । काही न लागती सायास"
          ]
        },
        {
          "type": "verse",
          "number": 106,
          "lines": [
            "एकाग्रचित्ते एकांती । अनुष्ठान कीजे मध्यराती ।",
            "बैसोनिया स्वस्थचित्ती । प्रत्यक्ष मूर्ति प्रकटेल"
          ]
        },
        {
          "type": "verse",
          "number": 107,
          "lines": [
            "तेथें देहभावासी नुरे ठाव । अवघा चतुर्भुज देव ।",
            "त्याचे चरणी ठेवोनि भाव । वरप्रसाद मागावा"
          ]
        },
        {
          "type": "conclusion",
          "number": 108,
          "lines": [
            "इति श्री देवी दास विरचितं श्री व्यंकटेश स्तोत्रं संपूर्णम ।",
            "।। श्री व्यंकटेशार्पणमस्तु ।।"
          ]
        }
      ]
    }
  ]
}
