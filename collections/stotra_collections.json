        }
      },
      "verses": [
        {
          "type": "verse",
          "number": 0,
          "lines": [
            "श्री गणेशाय नम:",
            "ॐ भद्रं कर्णेभि शृणुयाम देवा:",
            "भद्रं पश्येमाक्षभिर्यजत्रा:\n    स्थिरैरंगै स्तुष्टुवांसस्तनूभि:",
            "व्यशेम देवहितं यदायु:\n    ॥१॥"
          ]
        },
        {
          "type": "verse",
          "number": 2,
          "lines": [
            "ॐ स्वस्ति न इन्द्रो वृद्धश्रवा:",
            "स्वस्ति न: पूषा विश्ववेदा:",
            "स्वस्ति नस्तार्क्ष्यो अरिष्टनेमि:\n    स्वस्ति नो बृहस्पतिर्दधातु\n    ॥२॥",
            "ॐ शांति: शांति: शांति:\n    ॥"
          ]
        },
        {
          "type": "verse",
          "number": 3,
          "lines": [
            "ॐ नमस्ते गणपतये",
            "त्वमेव प्रत्यक्षं तत्वमसि\n    त्वमेव केवलं कर्तासि",
            "त्वमेव केवलं धर्तासि\n    त्वमेव केवलं हर्तासि",
            "त्वमेव सर्वं खल्विदं ब्रह्मासि\n    त्वं साक्षादात्मासि नित्यम्",
